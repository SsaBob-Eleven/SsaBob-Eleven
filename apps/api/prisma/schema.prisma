generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FlowMode {
  LOCATION_FIRST
  TEAM_FIRST
}

enum RoundStatus {
  SCHEDULED
  OPEN
  GENERATING
  PAUSED
  LOCATION_SELECTION
  COMPLETED
}

enum Location {
  FLOOR_10
  FLOOR_20
  OUTSIDE
}

enum GenerationTrigger {
  SCHEDULER
  ADMIN
  RECOVERY
}

model Participant {
  id             String         @id @default(uuid())
  name           String
  normalizedName String         @unique
  active         Boolean        @default(true)
  registrations  Registration[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Round {
  id                  String           @id @default(uuid())
  weekKey             String           @unique
  flowMode            FlowMode
  status              RoundStatus
  opensAt             DateTime
  closesAt            DateTime
  locationClosesAt    DateTime?
  groupSizePolicy     String           @default("ADAPTIVE")
  targetGroupMinSize  Int              @default(4)
  targetGroupMaxSize  Int              @default(5)
  maxParticipants     Int              @default(26)
  historyWeeks        Int              @default(8)
  randomAttempts      Int              @default(500)
  randomSeed          String?
  generationStartedAt DateTime?
  generatedAt         DateTime?
  completedAt         DateTime?
  registrations       Registration[]
  teams               Team[]
  generationAudit     GenerationAudit?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status, closesAt])
}

model Registration {
  id                String      @id @default(uuid())
  roundId           String
  participantId     String
  displayName       String
  preferredLocation Location?
  editTokenHash     String      @unique
  round             Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participant       Participant @relation(fields: [participantId], references: [id])
  teamMember        TeamMember?
  selectedLocations Team[]      @relation("LocationSelector")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([roundId, participantId])
  @@index([roundId])
}

model Team {
  id                               String        @id @default(uuid())
  roundId                          String
  sequence                         Int
  location                         Location?
  sizeAdjusted                     Boolean       @default(false)
  locationSelectedByRegistrationId String?
  locationSelectedAt               DateTime?
  round                            Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  locationSelectedBy               Registration? @relation("LocationSelector", fields: [locationSelectedByRegistrationId], references: [id], onDelete: SetNull)
  members                          TeamMember[]
  createdAt                        DateTime      @default(now())
  updatedAt                        DateTime      @updatedAt

  @@unique([roundId, sequence])
  @@index([roundId])
}

model TeamMember {
  teamId         String
  registrationId String       @unique
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([teamId, registrationId])
}

model GenerationAudit {
  id                    String            @id @default(uuid())
  roundId               String            @unique
  algorithmVersion      String
  trigger               GenerationTrigger
  triggerReason         String?
  candidateCount        Int
  bestScore             Float
  repeatedPairCount     Int
  sizeAdjustedTeamCount Int
  durationMs            Int
  round                 Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  createdAt             DateTime          @default(now())
}
